FROM debian:12-slim

ARG USERNAME
ARG UID
ARG GID

RUN apt update && \
    apt install -y nodejs npm busybox python3-dev python3-venv gcc g++ make bear sqlite3 git curl && \
    getent group | grep :${GID}: >/dev/null || groupadd --gid ${GID} ${USERNAME} && \
    useradd --uid ${UID} \
            --gid ${GID} \
            --create-home \
            --shell /bin/bash \
            ${USERNAME} && \
    rm -rf /var/lib/apt/lists/*

RUN npm install -g @openai/codex@0.92.0

USER ${USERNAME}
ENV COLORTERM=truecolor
ENV TERM=xterm-256color
ENV OPENAI_BASE_URL=http://172.17.0.1:8000/v1
ENV OPENAI_API_KEY=dummy
ENV NO_TELEMETRY=1
ENV DO_NOT_TRACK=1
ENV DISABLE_AUTOUPDATER=1

WORKDIR /home/${USERNAME}

# Write config.toml to force chat completions wire API
RUN mkdir -p .codex && cat > .codex/config.toml << 'EOF'
model = "openai/gpt-oss-120b"
model_provider = "vllm"
approval_policy = "never"

[model_providers.vllm]
name = "vLLM local"
base_url = "http://172.17.0.1:8000/v1"
env_key = "OPENAI_API_KEY"
wire_api = "chat"
EOF

RUN python3 -m venv .venv && \
    .venv/bin/pip install --upgrade pip && \
    .venv/bin/pip install pylint flake8 mypy

RUN cat >> .bashrc << EOF
alias codex='codex --dangerously-bypass-approvals-and-sandbox'
source /home/${USERNAME}/.venv/bin/activate
EOF

RUN cat >> .profile << EOF
source /home/${USERNAME}/.venv/bin/activate
EOF

ENV PATH="/home/${USERNAME}/.venv/bin:$PATH"

CMD ["codex", "--dangerously-bypass-approvals-and-sandbox"]
